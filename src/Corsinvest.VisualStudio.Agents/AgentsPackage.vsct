<?xml version="1.0" encoding="utf-8"?>
<CommandTable xmlns="http://schemas.microsoft.com/VisualStudio/2005-10-18/CommandTable"
              xmlns:xs="http://www.w3.org/2001/XMLSchema">

  <Extern href="stdidcmd.h"/>
  <Extern href="vsshlids.h"/>
  <!-- Brings in ImageCatalogGuid + an IDSymbol per KnownMoniker, so buttons can use VS's own
       icons (IconIsMoniker) instead of shipping a bitmap strip. -->
  <Include href="KnownImageIds.vsct"/>

  <Commands package="guidAgentsPackage">
    <Menus>
      <!-- Always-present submenu under View. Holds one dynamic entry per enabled profile
           (Options → Profiles), the native "Claude" profile included. -->
      <Menu guid="guidAgentsCommandSet" id="ProfilesSubMenu" priority="0x0100" type="Menu">
        <Parent guid="guidAgentsCommandSet" id="MyMenuGroup"/>
        <Icon guid="guidImages" id="bmpPic1" />
        <CommandFlag>IconAndText</CommandFlag>
        <Strings>
          <ButtonText>cv4vs Agents</ButtonText>
        </Strings>
      </Menu>

      <!-- Developer: diagnostic entries (data folder, output log) tucked out of the main list. -->
      <Menu guid="guidAgentsCommandSet" id="DeveloperSubMenu" priority="0x0200" type="Menu">
        <Parent guid="guidAgentsCommandSet" id="GlobalGroup"/>
        <Icon guid="ImageCatalogGuid" id="CodeInformation"/>
        <CommandFlag>IconIsMoniker</CommandFlag>
        <CommandFlag>IconAndText</CommandFlag>
        <Strings>
          <ButtonText>Developer</ButtonText>
        </Strings>
      </Menu>

      <!-- Help &amp; Feedback: docs first (it answers without bothering anyone), contact after. -->
      <Menu guid="guidAgentsCommandSet" id="HelpSubMenu" priority="0x0100" type="Menu">
        <Parent guid="guidAgentsCommandSet" id="HelpGroup"/>
        <Icon guid="ImageCatalogGuid" id="StatusHelpOutline"/>
        <CommandFlag>IconIsMoniker</CommandFlag>
        <CommandFlag>IconAndText</CommandFlag>
        <Strings>
          <ButtonText>Help &amp; Feedback</ButtonText>
        </Strings>
      </Menu>
    </Menus>

    <Groups>
      <!-- Anchors the submenu under the View menu. -->
      <Group guid="guidAgentsCommandSet" id="MyMenuGroup" priority="0x0600">
        <Parent guid="guidSHLMainMenu" id="IDM_VS_MENU_VIEW"/>
      </Group>
      <!-- Group inside the submenu holding the entries. -->
      <Group guid="guidAgentsCommandSet" id="ProfilesGroup" priority="0x0100">
        <Parent guid="guidAgentsCommandSet" id="ProfilesSubMenu"/>
      </Group>
      <!-- Statistics on its own, between profiles and the global actions (auto separators). -->
      <Group guid="guidAgentsCommandSet" id="StatisticsGroup" priority="0x0180">
        <Parent guid="guidAgentsCommandSet" id="ProfilesSubMenu"/>
      </Group>
      <!-- Global (not per-pane) entries. Separate groups because VS draws the separators
           between groups — no <Separator> needed. -->
      <Group guid="guidAgentsCommandSet" id="GlobalGroup" priority="0x0200">
        <Parent guid="guidAgentsCommandSet" id="ProfilesSubMenu"/>
      </Group>
      <Group guid="guidAgentsCommandSet" id="HelpGroup" priority="0x0300">
        <Parent guid="guidAgentsCommandSet" id="ProfilesSubMenu"/>
      </Group>
      <!-- Entries inside the Developer submenu. -->
      <Group guid="guidAgentsCommandSet" id="DeveloperGroup" priority="0x0100">
        <Parent guid="guidAgentsCommandSet" id="DeveloperSubMenu"/>
      </Group>
      <Group guid="guidAgentsCommandSet" id="HelpDocsGroup" priority="0x0100">
        <Parent guid="guidAgentsCommandSet" id="HelpSubMenu"/>
      </Group>
      <Group guid="guidAgentsCommandSet" id="HelpContactGroup" priority="0x0200">
        <Parent guid="guidAgentsCommandSet" id="HelpSubMenu"/>
      </Group>
    </Groups>

    <Buttons>
      <!-- Dynamic range inside the submenu: one item per enabled profile, the native "Claude"
           profile prepended (unless a profile is itself named "Claude"). Seeded by DynamicItemStart. -->
      <Button guid="guidAgentsCommandSet" id="ShowToolWindowCommandId" priority="0x0100" type="Button">
        <Parent guid="guidAgentsCommandSet" id="ProfilesGroup"/>
        <CommandFlag>DynamicItemStart</CommandFlag>
        <CommandFlag>DynamicVisibility</CommandFlag>
        <CommandFlag>TextChanges</CommandFlag>
        <Strings>
          <ButtonText>Claude</ButtonText>
        </Strings>
      </Button>

      <Button guid="guidAgentsCommandSet" id="SettingsCommandId" priority="0x0100" type="Button">
        <Parent guid="guidAgentsCommandSet" id="GlobalGroup"/>
        <Icon guid="ImageCatalogGuid" id="Settings"/>
        <CommandFlag>IconIsMoniker</CommandFlag>
        <Strings><ButtonText>Settings</ButtonText></Strings>
      </Button>
      <Button guid="guidAgentsCommandSet" id="DataFolderCommandId" priority="0x0100" type="Button">
        <Parent guid="guidAgentsCommandSet" id="DeveloperGroup"/>
        <Icon guid="ImageCatalogGuid" id="OpenFolder"/>
        <CommandFlag>IconIsMoniker</CommandFlag>
        <Strings><ButtonText>Open data folder</ButtonText></Strings>
      </Button>
      <Button guid="guidAgentsCommandSet" id="OutputLogCommandId" priority="0x0200" type="Button">
        <Parent guid="guidAgentsCommandSet" id="DeveloperGroup"/>
        <Icon guid="ImageCatalogGuid" id="Output"/>
        <CommandFlag>IconIsMoniker</CommandFlag>
        <Strings><ButtonText>View output log</ButtonText></Strings>
      </Button>
      <Button guid="guidAgentsCommandSet" id="StatisticsCommandId" priority="0x0100" type="Button">
        <Parent guid="guidAgentsCommandSet" id="StatisticsGroup"/>
        <Icon guid="ImageCatalogGuid" id="Statistics"/>
        <CommandFlag>IconIsMoniker</CommandFlag>
        <Strings><ButtonText>Statistics</ButtonText></Strings>
      </Button>
      <Button guid="guidAgentsCommandSet" id="UsageCommandId" priority="0x0200" type="Button">
        <Parent guid="guidAgentsCommandSet" id="StatisticsGroup"/>
        <Icon guid="ImageCatalogGuid" id="CloudGroup"/>
        <CommandFlag>IconIsMoniker</CommandFlag>
        <Strings><ButtonText>Usage</ButtonText></Strings>
      </Button>
      <Button guid="guidAgentsCommandSet" id="ContextUsageCommandId" priority="0x0300" type="Button">
        <Parent guid="guidAgentsCommandSet" id="StatisticsGroup"/>
        <Icon guid="ImageCatalogGuid" id="MemoryWindow"/>
        <CommandFlag>IconIsMoniker</CommandFlag>
        <Strings><ButtonText>Context usage</ButtonText></Strings>
      </Button>

      <Button guid="guidAgentsCommandSet" id="DocumentationCommandId" priority="0x0100" type="Button">
        <Parent guid="guidAgentsCommandSet" id="HelpDocsGroup"/>
        <Icon guid="ImageCatalogGuid" id="StatusHelpOutline"/>
        <CommandFlag>IconIsMoniker</CommandFlag>
        <Strings><ButtonText>Documentation</ButtonText></Strings>
      </Button>
      <Button guid="guidAgentsCommandSet" id="ReportBugCommandId" priority="0x0100" type="Button">
        <Parent guid="guidAgentsCommandSet" id="HelpContactGroup"/>
        <Icon guid="ImageCatalogGuid" id="StatusWarning"/>
        <CommandFlag>IconIsMoniker</CommandFlag>
        <Strings><ButtonText>Report a Bug</ButtonText></Strings>
      </Button>
      <Button guid="guidAgentsCommandSet" id="RequestFeatureCommandId" priority="0x0200" type="Button">
        <Parent guid="guidAgentsCommandSet" id="HelpContactGroup"/>
        <Icon guid="ImageCatalogGuid" id="IntellisenseLightBulb"/>
        <CommandFlag>IconIsMoniker</CommandFlag>
        <Strings><ButtonText>Request a Feature</ButtonText></Strings>
      </Button>
      <Button guid="guidAgentsCommandSet" id="FeedbackCommandId" priority="0x0300" type="Button">
        <Parent guid="guidAgentsCommandSet" id="HelpContactGroup"/>
        <Icon guid="ImageCatalogGuid" id="Feedback"/>
        <CommandFlag>IconIsMoniker</CommandFlag>
        <Strings><ButtonText>Provide Feedback</ButtonText></Strings>
      </Button>

      <Button guid="guidAgentsCommandSet" id="ReleasesCommandId" priority="0x0150" type="Button">
        <Parent guid="guidAgentsCommandSet" id="HelpGroup"/>
        <Strings><ButtonText>Release Notes</ButtonText></Strings>
      </Button>
      <Button guid="guidAgentsCommandSet" id="AboutCommandId" priority="0x0200" type="Button">
        <Parent guid="guidAgentsCommandSet" id="HelpGroup"/>
        <Icon guid="ImageCatalogGuid" id="StatusInformation"/>
        <CommandFlag>IconIsMoniker</CommandFlag>
        <Strings><ButtonText>About</ButtonText></Strings>
      </Button>
    </Buttons>

    <Bitmaps>
      <Bitmap guid="guidImages" href="Resources\icon.png" usedList="bmpPic1"/>
    </Bitmaps>
  </Commands>

  <Symbols>
    <GuidSymbol name="guidAgentsPackage" value="{b1c2d3e4-f5a6-7890-bcde-fa1234567890}" />
    <GuidSymbol name="guidAgentsCommandSet" value="{a2b3c4d5-e6f7-8901-cdef-ab1234567890}">
      <IDSymbol name="MyMenuGroup" value="0x1020" />
      <IDSymbol name="ProfilesSubMenu" value="0x1030" />
      <IDSymbol name="ProfilesGroup" value="0x1040" />
      <IDSymbol name="StatisticsGroup" value="0x1045" />
      <IDSymbol name="GlobalGroup" value="0x1050" />
      <IDSymbol name="HelpGroup" value="0x1060" />
      <IDSymbol name="HelpSubMenu" value="0x1070" />
      <IDSymbol name="DeveloperSubMenu" value="0x1075" />
      <IDSymbol name="DeveloperGroup" value="0x1076" />
      <IDSymbol name="HelpDocsGroup" value="0x1080" />
      <IDSymbol name="HelpContactGroup" value="0x1090" />
      <!-- Must match PackageIds.cs — a mismatch is silent: the entry just never appears. -->
      <IDSymbol name="ShowToolWindowCommandId" value="0x0100" />
      <IDSymbol name="SettingsCommandId" value="0x0200" />
      <IDSymbol name="DataFolderCommandId" value="0x0201" />
      <IDSymbol name="OutputLogCommandId" value="0x0202" />
      <IDSymbol name="DocumentationCommandId" value="0x0203" />
      <IDSymbol name="ReportBugCommandId" value="0x0204" />
      <IDSymbol name="RequestFeatureCommandId" value="0x0205" />
      <IDSymbol name="FeedbackCommandId" value="0x0206" />
      <IDSymbol name="AboutCommandId" value="0x0207" />
      <IDSymbol name="ReleasesCommandId" value="0x0208" />
      <IDSymbol name="StatisticsCommandId" value="0x0209" />
      <IDSymbol name="UsageCommandId" value="0x020A" />
      <IDSymbol name="ContextUsageCommandId" value="0x020B" />
    </GuidSymbol>
    <GuidSymbol name="guidImages" value="{c3d4e5f6-a7b8-9012-defa-bc1234567890}">
      <IDSymbol name="bmpPic1" value="1" />
    </GuidSymbol>
  </Symbols>

</CommandTable>
