  <!-- Reference VS's built-in Microsoft.Terminal.Wpf (used by the integrated
       VS terminal). Path varies between channels: Community/Pro/Enterprise
       use Common7\IDE\CommonExtensions\Microsoft\Terminal directly; some
       Canary/Insiders builds nest it under Terminal.Wpf\. We probe both.
       Private=False because the DLL is already in VS's AppDomain at runtime
       — we don't bundle it into the VSIX. -->
  <PropertyGroup>
    <_TerminalWpfBase>$(VsInstallRoot)\Common7\IDE\CommonExtensions\Microsoft\Terminal</_TerminalWpfBase>
    <_TerminalWpfDll Condition="Exists('$(_TerminalWpfBase)\Microsoft.Terminal.Wpf.dll')">$(_TerminalWpfBase)\Microsoft.Terminal.Wpf.dll</_TerminalWpfDll>
    <_TerminalWpfDll Condition="'$(_TerminalWpfDll)' == '' And Exists('$(_TerminalWpfBase)\Terminal.Wpf\Microsoft.Terminal.Wpf.dll')">$(_TerminalWpfBase)\Terminal.Wpf\Microsoft.Terminal.Wpf.dll</_TerminalWpfDll>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="Microsoft.Terminal.Wpf">
