<UserControl x:Class="Corsinvest.VisualStudio.Agents.Core.Panes.CvLoadingOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Center" VerticalAlignment="Center">
  <!-- A centered indeterminate progress bar with a caption under it. The caller places it
       (Grid.Column/Row) and toggles its Visibility; Message is the line shown below the bar. -->
  <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
    <ProgressBar IsIndeterminate="True" Width="180" Height="4" />
    <TextBlock Text="{Binding Message, RelativeSource={RelativeSource AncestorType=UserControl}}"
               HorizontalAlignment="Center" Margin="0,10,0,0" Opacity="0.7" />
  </StackPanel>
</UserControl>
