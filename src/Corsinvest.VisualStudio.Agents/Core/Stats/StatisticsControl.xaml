<UserControl x:Class="Corsinvest.VisualStudio.Agents.Core.Stats.StatisticsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
             toolkit:Themes.UseVsTheme="True">
  <UserControl.Resources>
    <!-- Summary tile: a bordered block with an uppercase label over a large value. -->
    <Style x:Key="TileStyle" TargetType="Border">
      <Setter Property="BorderBrush"
              Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="Margin" Value="0,0,10,0" />
    </Style>
    <Style x:Key="TileLabelStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Opacity" Value="0.7" />
      <Setter Property="Margin" Value="0,0,0,2" />
    </Style>
    <Style x:Key="TileValueStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
  </UserControl.Resources>

  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Toolbar: scope + range + indexing state + export (disabled placeholder). -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
      <TextBlock Text="Scope" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.7" />
      <ComboBox x:Name="ScopeCombo" Width="150" VerticalAlignment="Center"
                SelectionChanged="OnFilterChanged">
        <ComboBoxItem Content="All projects" IsSelected="True" />
        <ComboBoxItem Content="Current project" />
      </ComboBox>
      <TextBlock Text="Range" VerticalAlignment="Center" Margin="16,0,6,0" Opacity="0.7" />
      <ComboBox x:Name="RangeCombo" Width="110" VerticalAlignment="Center"
                SelectionChanged="OnFilterChanged">
        <ComboBoxItem Content="Last 7 days" />
        <ComboBoxItem Content="Last 30 days" IsSelected="True" />
        <ComboBoxItem Content="All time" />
      </ComboBox>
      <TextBlock x:Name="IndexingText" Text="Indexing…" VerticalAlignment="Center"
                 Margin="16,0,0,0" Opacity="0.7" Visibility="Collapsed" />
      <Button x:Name="ExportButton" Content="Export xlsx" Width="100" Margin="16,0,0,0"
              VerticalAlignment="Center" IsEnabled="False" ToolTip="Coming soon" />
    </StackPanel>

    <!-- Summary tiles. -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,14">
      <Border Style="{StaticResource TileStyle}">
        <StackPanel>
          <TextBlock Text="TOTAL TOKENS" Style="{StaticResource TileLabelStyle}" />
          <TextBlock x:Name="TotalTokensText" Text="—" Style="{StaticResource TileValueStyle}" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource TileStyle}">
        <StackPanel>
          <TextBlock Text="SESSIONS" Style="{StaticResource TileLabelStyle}" />
          <TextBlock x:Name="SessionsText" Text="—" Style="{StaticResource TileValueStyle}" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource TileStyle}">
        <StackPanel>
          <TextBlock Text="MESSAGES" Style="{StaticResource TileLabelStyle}" />
          <TextBlock x:Name="MessagesText" Text="—" Style="{StaticResource TileValueStyle}" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource TileStyle}">
        <StackPanel>
          <TextBlock Text="TOOL CALLS" Style="{StaticResource TileLabelStyle}" />
          <TextBlock x:Name="ToolCallsText" Text="—" Style="{StaticResource TileValueStyle}" />
        </StackPanel>
      </Border>
    </StackPanel>

    <!-- Per-model breakdown table (no cost column — cost is a future phase). -->
    <DataGrid Grid.Row="2" x:Name="ModelGrid" AutoGenerateColumns="False"
              IsReadOnly="True" HeadersVisibility="Column"
              GridLinesVisibility="Horizontal" CanUserAddRows="False">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="*" />
        <DataGridTextColumn Header="Input" Binding="{Binding InputTokens, StringFormat=N0}" Width="Auto" />
        <DataGridTextColumn Header="Output" Binding="{Binding OutputTokens, StringFormat=N0}" Width="Auto" />
        <DataGridTextColumn Header="Cache read" Binding="{Binding CacheReadTokens, StringFormat=N0}" Width="Auto" />
        <DataGridTextColumn Header="Cache creation" Binding="{Binding CacheCreationTokens, StringFormat=N0}" Width="Auto" />
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>
