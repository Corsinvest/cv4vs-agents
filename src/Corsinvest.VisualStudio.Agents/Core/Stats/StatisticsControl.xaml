<UserControl x:Class="Corsinvest.VisualStudio.Agents.Core.Stats.StatisticsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
             xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
             xmlns:catalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
             xmlns:stats="clr-namespace:Corsinvest.VisualStudio.Agents.Core.Stats"
             toolkit:Themes.UseVsTheme="True">
  <UserControl.Resources>
    <stats:ScopeIconConverter x:Key="ScopeIconConverter" />
    <!-- Summary tile: bordered block, uppercase label over a large value. -->
    <Style x:Key="TileStyle" TargetType="Border">
      <Setter Property="BorderBrush"
              Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="Margin" Value="0,0,10,10" />
    </Style>
    <!-- Value on top (big), label under it (small) — KPI-card order, like the WebView dialog. -->
    <Style x:Key="TileValueStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="TileLabelStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Opacity" Value="0.7" />
      <Setter Property="Margin" Value="0,2,0,0" />
    </Style>
    <Style x:Key="SectionHeadStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Opacity" Value="0.7" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>
  </UserControl.Resources>

  <!-- Columns: scope tree | draggable splitter | Overview | Models. The tree column is
       user-resizable (min 140) via the GridSplitter. Toolbar + range live above the tree. -->
  <Grid Margin="14">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="220" MinWidth="140" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- Column 0: a small icon toolbar (Refresh / Recreate) over the scope tree. -->
      <Grid Grid.Column="0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Tree toolbar: compact flat icon buttons (WPF ToolBar drags a grip + overflow chevron
             that don't theme cleanly, so a plain StackPanel with a small flat button style instead). -->
        <StackPanel x:Name="TreeToolbar" Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
          <StackPanel.Resources>
            <Style x:Key="ToolBtn" TargetType="Button">
              <Setter Property="Width" Value="22" />
              <Setter Property="Height" Value="22" />
              <Setter Property="Padding" Value="0" />
              <Setter Property="Margin" Value="0,0,2,0" />
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="BorderBrush" Value="Transparent" />
              <Setter Property="BorderThickness" Value="1" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                      <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="bd" Property="Background"
                                Value="{DynamicResource {x:Static vsui:EnvironmentColors.CommandBarMouseOverBackgroundBeginBrushKey}}" />
                        <Setter TargetName="bd" Property="BorderBrush"
                                Value="{DynamicResource {x:Static vsui:EnvironmentColors.CommandBarBorderBrushKey}}" />
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </StackPanel.Resources>
          <!-- The two action buttons; replaced in-place by the indexing indicator while a pass runs. -->
          <StackPanel x:Name="RefreshButtons" Orientation="Horizontal">
            <Button Style="{StaticResource ToolBtn}" Click="OnRefreshClick"
                    ToolTip="Refresh — re-read changed sessions">
              <imaging:CrispImage Width="16" Height="16"
                                  Moniker="{x:Static catalog:KnownMonikers.Refresh}" />
            </Button>
            <Button Style="{StaticResource ToolBtn}" Click="OnRecreateClick"
                    ToolTip="Recreate statistics — re-index everything from scratch">
              <imaging:CrispImage Width="16" Height="16"
                                  Moniker="{x:Static catalog:KnownMonikers.Restart}" />
            </Button>
          </StackPanel>
          <!-- Shown in the buttons' place while indexing: an indeterminate bar + label. -->
          <StackPanel x:Name="IndexingPanel" Orientation="Horizontal" VerticalAlignment="Center"
                      Visibility="Collapsed">
            <ProgressBar IsIndeterminate="True" Width="60" Height="4" VerticalAlignment="Center" />
            <TextBlock Text="Indexing…" VerticalAlignment="Center" Margin="6,0,0,0" Opacity="0.7" />
          </StackPanel>
          <!-- Separator, then the range filter (applies to both the tree and the stats). -->
          <Rectangle Width="1" Height="16" Margin="4,0,6,0" VerticalAlignment="Center"
                     Fill="{DynamicResource {x:Static vsui:EnvironmentColors.CommandBarBorderBrushKey}}" />
          <ComboBox x:Name="RangeCombo" Height="22" MinWidth="96" Padding="6,0" VerticalAlignment="Center"
                    VerticalContentAlignment="Center" SelectionChanged="OnFilterChanged">
            <ComboBoxItem Content="Last 7 days" />
            <ComboBoxItem Content="Last 30 days" />
            <ComboBoxItem Content="All time" IsSelected="True" />
          </ComboBox>
        </StackPanel>

      <!-- Scope tree: All → Profile → Folder → Project → Day → Session; every node is clickable and
           recomputes. Native WPF TreeView doesn't follow the VS theme on its own, so bind its colours
           to the theme brushes (works in both light and dark). -->
      <TreeView x:Name="ScopeTree" Grid.Row="1"
                BorderThickness="1"
                Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
                Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"
                BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}"
                SelectedItemChanged="OnScopeSelected">
        <TreeView.ItemContainerStyle>
          <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
            <!-- Inherit the theme text colour on every item (the TextBlock reads it). -->
            <Setter Property="Foreground"
                    Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
          </Style>
        </TreeView.ItemContainerStyle>
        <TreeView.Resources>
          <HierarchicalDataTemplate DataType="{x:Type stats:StatsTreeNode}"
                                    ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" ToolTip="{Binding Tooltip}">
              <imaging:CrispImage Width="16" Height="16" Margin="0,0,6,0"
                                  VerticalAlignment="Center"
                                  Moniker="{Binding Converter={StaticResource ScopeIconConverter}}" />
              <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
            </StackPanel>
          </HierarchicalDataTemplate>
        </TreeView.Resources>
      </TreeView>
      </Grid>

      <!-- Draggable divider: resizes the tree column. -->
      <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center"
                    VerticalAlignment="Stretch" Background="Transparent" />

      <!-- Overview: summary tiles + (charts come in the next phase). -->
      <StackPanel Grid.Column="2" Margin="10,0,20,0">
        <TextBlock Text="OVERVIEW" Style="{StaticResource SectionHeadStyle}" />
        <UniformGrid Columns="4">
          <Border Style="{StaticResource TileStyle}">
            <StackPanel>
              <TextBlock x:Name="TotalTokensText" Text="—" Style="{StaticResource TileValueStyle}" />
              <TextBlock Text="TOTAL TOKENS" Style="{StaticResource TileLabelStyle}" />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource TileStyle}">
            <StackPanel>
              <TextBlock x:Name="InputTokensText" Text="—" Style="{StaticResource TileValueStyle}" />
              <TextBlock Text="INPUT TOKENS" Style="{StaticResource TileLabelStyle}" />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource TileStyle}">
            <StackPanel>
              <TextBlock x:Name="OutputTokensText" Text="—" Style="{StaticResource TileValueStyle}" />
              <TextBlock Text="OUTPUT TOKENS" Style="{StaticResource TileLabelStyle}" />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource TileStyle}">
            <StackPanel>
              <TextBlock x:Name="CacheTokensText" Text="—" Style="{StaticResource TileValueStyle}" />
              <TextBlock Text="CACHE TOKENS" Style="{StaticResource TileLabelStyle}" />
            </StackPanel>
          </Border>
          <!-- Row 2: volume -->
          <Border Style="{StaticResource TileStyle}">
            <StackPanel>
              <TextBlock x:Name="SessionsText" Text="—" Style="{StaticResource TileValueStyle}" />
              <TextBlock Text="SESSIONS" Style="{StaticResource TileLabelStyle}" />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource TileStyle}">
            <StackPanel>
              <TextBlock x:Name="MessagesText" Text="—" Style="{StaticResource TileValueStyle}" />
              <TextBlock Text="MESSAGES" Style="{StaticResource TileLabelStyle}" />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource TileStyle}">
            <StackPanel>
              <TextBlock x:Name="ToolCallsText" Text="—" Style="{StaticResource TileValueStyle}" />
              <TextBlock Text="TOOL CALLS" Style="{StaticResource TileLabelStyle}" />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource TileStyle}">
            <StackPanel>
              <TextBlock x:Name="SubagentsText" Text="—" Style="{StaticResource TileValueStyle}" />
              <TextBlock Text="SUBAGENTS" Style="{StaticResource TileLabelStyle}" />
            </StackPanel>
          </Border>
          <!-- Row 3: sub-agent tokens + activity -->
          <Border Style="{StaticResource TileStyle}">
            <StackPanel>
              <TextBlock x:Name="SubagentTokensText" Text="—" Style="{StaticResource TileValueStyle}" />
              <TextBlock Text="SUBAGENT TOKENS" Style="{StaticResource TileLabelStyle}" />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource TileStyle}">
            <StackPanel>
              <TextBlock x:Name="ActiveDaysText" Text="—" Style="{StaticResource TileValueStyle}" />
              <TextBlock Text="ACTIVE DAYS" Style="{StaticResource TileLabelStyle}" />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource TileStyle}">
            <StackPanel>
              <TextBlock x:Name="CurrentStreakText" Text="—" Style="{StaticResource TileValueStyle}" />
              <TextBlock Text="CURRENT STREAK" Style="{StaticResource TileLabelStyle}" />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource TileStyle}">
            <StackPanel>
              <TextBlock x:Name="LongestStreakText" Text="—" Style="{StaticResource TileValueStyle}" />
              <TextBlock Text="LONGEST STREAK" Style="{StaticResource TileLabelStyle}" />
            </StackPanel>
          </Border>
          <!-- Row 4: meta -->
          <Border Style="{StaticResource TileStyle}">
            <StackPanel>
              <TextBlock x:Name="PeakHourText" Text="—" Style="{StaticResource TileValueStyle}" />
              <TextBlock Text="PEAK HOUR" Style="{StaticResource TileLabelStyle}" />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource TileStyle}">
            <StackPanel>
              <TextBlock x:Name="FavoriteModelText" Text="—" Style="{StaticResource TileValueStyle}"
                         TextTrimming="CharacterEllipsis" MaxWidth="200" />
              <TextBlock Text="FAVORITE MODEL" Style="{StaticResource TileLabelStyle}" />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource TileStyle}">
            <StackPanel>
              <TextBlock x:Name="ImagesText" Text="—" Style="{StaticResource TileValueStyle}" />
              <TextBlock Text="IMAGES" Style="{StaticResource TileLabelStyle}" />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource TileStyle}">
            <StackPanel>
              <TextBlock x:Name="AttachmentsText" Text="—" Style="{StaticResource TileValueStyle}" />
              <TextBlock Text="ATTACHMENTS" Style="{StaticResource TileLabelStyle}" />
            </StackPanel>
          </Border>
        </UniformGrid>
        <!-- Activity heatmap (GitHub-style) — same look as the WebView dialog. -->
        <TextBlock Text="ACTIVITY" Style="{StaticResource SectionHeadStyle}" Margin="0,10,0,10" />
        <stats:CvHeatmap x:Name="Heatmap" HorizontalAlignment="Left" />
      </StackPanel>

      <!-- Models: per-model row = name + % + share bar + in/out tokens (mirrors the WebView dialog). -->
      <StackPanel Grid.Column="3">
        <TextBlock Text="MODELS" Style="{StaticResource SectionHeadStyle}" />
        <ItemsControl x:Name="ModelsList">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <StackPanel Margin="0,0,0,12">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <Ellipse Grid.Column="0" Width="9" Height="9" Margin="0,0,7,0"
                           VerticalAlignment="Center" Fill="{Binding Color}" />
                  <TextBlock Grid.Column="1" Text="{Binding Model}"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="2" Text="{Binding Percentage, StringFormat={}{0:F1}%}"
                             Opacity="0.7" Margin="8,0,0,0" />
                </Grid>
                <ProgressBar Height="6" Margin="0,4" Foreground="{Binding Color}"
                             Minimum="0" Maximum="100" Value="{Binding Percentage}" />
                <StackPanel Orientation="Horizontal">
                  <TextBlock Opacity="0.7" FontSize="11"
                             Text="{Binding InputTokens, StringFormat=N0}" />
                  <TextBlock Opacity="0.7" FontSize="11" Text=" in · " />
                  <TextBlock Opacity="0.7" FontSize="11"
                             Text="{Binding OutputTokens, StringFormat=N0}" />
                  <TextBlock Opacity="0.7" FontSize="11" Text=" out" />
                </StackPanel>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <!-- Daily tokens, stacked per model (same colours as the MODELS list above). -->
        <TextBlock Text="DAILY TOKENS" Style="{StaticResource SectionHeadStyle}" Margin="0,20,0,10" />
        <stats:CvBarChart x:Name="BarChart" Height="230" HorizontalAlignment="Stretch" />
      </StackPanel>
  </Grid>
</UserControl>
