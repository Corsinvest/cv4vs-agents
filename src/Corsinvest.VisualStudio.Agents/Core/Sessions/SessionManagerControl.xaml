<UserControl x:Class="Corsinvest.VisualStudio.Agents.Core.Sessions.SessionManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
             xmlns:catalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
             xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
             toolkit:Themes.UseVsTheme="True"
             PreviewKeyDown="OnPreviewKeyDown">
  <UserControl.Resources>

    <!-- Inverse of BooleanToVisibilityConverter: true → Collapsed.
         Used to hide the static title TextBlock while the row is in
         inline-edit mode (the TextBox is shown instead). -->
    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <!-- Single row in the session list. Hover reveals the action icons
         and tints the background using the VS command-bar hover brush. -->
    <Style x:Key="SessionRowStyle" TargetType="Border">
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Cursor" Value="Hand" />
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background"
                  Value="{DynamicResource {x:Static vsui:EnvironmentColors.CommandBarHoverBrushKey}}" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- Small action button shown only on row hover (rename / delete). -->
    <Style x:Key="RowActionButtonStyle" TargetType="Button">
      <Setter Property="Padding" Value="4,2" />
      <Setter Property="Margin" Value="2,0,0,0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Visibility" Value="Collapsed" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background"
                        Value="{DynamicResource {x:Static vsui:EnvironmentColors.CommandBarMouseOverBackgroundBeginBrushKey}}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Search box, separated from the list by the same border tone VS
         uses for dropdown menu separators. -->
    <Border Grid.Row="0" Padding="8,6"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.DropDownPopupBorderBrushKey}}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <imaging:CrispImage Grid.Column="0" Width="14" Height="14" Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            Moniker="{x:Static catalog:KnownMonikers.Search}" />
        <!-- No Background/BorderThickness overrides: those would defeat the
             native VS TextBox style applied by toolkit:Themes.UseVsTheme
             on the root UserControl (caret, focus border, hover all come
             from the theme for free). Height kept compact to match the
             search-row density of VS popups. -->
        <TextBox Grid.Column="1" x:Name="SearchBox"
                 Height="22"
                 Padding="4,0"
                 VerticalContentAlignment="Center"
                 TextChanged="OnSearchChanged"
                 KeyDown="OnSearchKeyDown" />
      </Grid>
    </Border>

    <!-- Sessions list (filtered). ListBox (not ItemsControl) so we get
         arrow up/down keyboard navigation + selection highlight for free.
         The default ListBoxItem chrome is stripped via ItemContainerStyle
         so our SessionRowStyle owns the look. -->
    <ListBox Grid.Row="1" x:Name="SessionsList"
             MaxHeight="400"
             BorderThickness="0"
             Background="Transparent"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             KeyDown="OnListKeyDown">
      <ListBox.ItemContainerStyle>
        <Style TargetType="ListBoxItem">
          <Setter Property="Padding" Value="0" />
          <Setter Property="Margin" Value="0" />
          <Setter Property="BorderThickness" Value="0" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="HorizontalContentAlignment" Value="Stretch" />
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="ListBoxItem">
                <Border x:Name="bd" Background="{TemplateBinding Background}">
                  <ContentPresenter />
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="Background"
                            Value="{DynamicResource {x:Static vsui:EnvironmentColors.DropDownMouseOverBackgroundBeginBrushKey}}" />
                  </Trigger>
                  <Trigger Property="IsSelected" Value="True">
                    <Setter TargetName="bd" Property="Background"
                            Value="{DynamicResource {x:Static vsui:EnvironmentColors.DropDownMouseDownBackgroundBrushKey}}" />
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </ListBox.ItemContainerStyle>
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Padding="8,4" Tag="{Binding Id}"
                  MouseLeftButtonUp="OnRow_Click"
                  ToolTip="{Binding TooltipText}"
                  Background="Transparent">
            <Grid>
              <Grid.ColumnDefinitions>
                <!-- Fixed-width gutter so the ✓ marker on the active row
                     doesn't shift titles. Empty when IsActive=false. -->
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Column="0"
                         Text="✓"
                         VerticalAlignment="Center"
                         FontWeight="Bold"
                         Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}" />

              <!-- Read-only title (visible when not editing) overlapped with
                   the inline edit TextBox (visible when IsEditing). Same
                   grid cell so the row layout doesn't jump on enter/exit
                   of edit mode. The TextBlock starts visible and a
                   DataTrigger collapses it when IsEditing flips on; the
                   TextBox does the opposite via the converter. -->
              <Grid Grid.Column="1">
                <TextBlock VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis">
                  <TextBlock.Text>
                    <Binding Path="DisplayTitle" />
                  </TextBlock.Text>
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Visibility" Value="Visible" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
                <TextBox x:Name="EditBox"
                         Text="{Binding EditBuffer, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         Padding="2,0"
                         KeyDown="OnEditKeyDown"
                         LostFocus="OnEditLostFocus"
                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}" />
              </Grid>

              <TextBlock Grid.Column="2"
                         Text="{Binding TimeAgoText}"
                         Margin="8,0,0,0"
                         VerticalAlignment="Center"
                         Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.SystemGrayTextBrushKey}}"
                         FontSize="11" />

              <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="6,0,0,0">
                <Button x:Name="BtnRename" Style="{StaticResource RowActionButtonStyle}"
                        ToolTip="Rename" Click="OnRename_Click" Tag="{Binding}">
                  <imaging:CrispImage Width="14" Height="14"
                                      Moniker="{x:Static catalog:KnownMonikers.Edit}" />
                </Button>
                <Button x:Name="BtnDelete" Style="{StaticResource RowActionButtonStyle}"
                        ToolTip="Delete" Click="OnDelete_Click" Tag="{Binding}">
                  <imaging:CrispImage Width="14" Height="14"
                                      Moniker="{x:Static catalog:KnownMonikers.DeleteListItem}" />
                </Button>
              </StackPanel>
            </Grid>
          </Border>
          <DataTemplate.Triggers>
            <DataTrigger
                Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}"
                Value="True">
              <Setter TargetName="BtnRename" Property="Visibility" Value="Visible" />
              <Setter TargetName="BtnDelete" Property="Visibility" Value="Visible" />
            </DataTrigger>
            <!-- Order matters: this trigger comes AFTER the hover one so
                 it wins when both are active — entering edit mode hides
                 the action buttons even if the mouse is still over the row. -->
            <DataTrigger Binding="{Binding IsEditing}" Value="True">
              <Setter TargetName="BtnRename" Property="Visibility" Value="Collapsed" />
              <Setter TargetName="BtnDelete" Property="Visibility" Value="Collapsed" />
            </DataTrigger>
          </DataTemplate.Triggers>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <!-- Empty state hint -->
    <TextBlock Grid.Row="2" x:Name="EmptyHint"
               Text="No sessions found." Margin="12,8"
               Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.SystemGrayTextBrushKey}}"
               Visibility="Collapsed" />

  </Grid>
</UserControl>
